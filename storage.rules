rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: controlla se l'utente è loggato
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Regole per le ricevute (scontrini)
    match /events/{eventId}/receipts/{fileName} {
      allow read: if true;
      allow create: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
      allow update: if true;
    }

    // Regole per la foto di copertina dell'evento (post-evento)
    match /events/{eventId}/cover/{fileName} {
      allow read: if true;
      allow create: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
      allow update: if true;
    }
  }
}
